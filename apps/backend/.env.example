# This is an example of the .env file for the backend application.

# JWT Configuration
JWT_SECRET=yourHighlySecureAndLongSecretKeyGoesHere
JWT_EXPIRES_IN=1h
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# MongoDB Connection
DB_CLIENT_URL=mongodb://root:password@localhost:27017/analytodon_dev?authSource=admin

# Mastodon Configuration
MASTODON_APP_NAME=Analytodon

# URL Configuration
FRONTEND_URL=http://localhost:5173
MARKETING_URL=https://www.analytodon.com

# Encryption Key (MUST be a 64-character hex string - 32 bytes)
# This dev key is shared across backend and CLI for local development:
ENCRYPTION_KEY=564C5209BF6AE728EDBDCAA91DCC6E4604CC8A378732306CB4CC74A2A5338C23

# Email Configuration (Mailpit defaults for local development)
# Mailpit Web UI: http://localhost:8025
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=mailpit
EMAIL_PASS=mailpit
EMAIL_SECURE=false
EMAIL_FROM_NAME="Analytodon"
EMAIL_FROM_ADDRESS=dev@analytodon.local

# Email API Configuration
EMAIL_API_KEY=your_email_api_key_here

# Feature Flags
DISABLE_NEW_REGISTRATIONS=false
