<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
  <style>
    body {
      font-family: 'Inter', 'Roboto', 'Helvetica', 'Arial', sans-serif;
      line-height: 1.6;
      color: #455a64;
      background-color: #f5f7fa;
      margin: 0;
      padding: 0;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
      background-color: #ffffff;
      border-radius: 8px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }
    .header {
      text-align: center;
      padding: 20px 0;
      border-bottom: 1px solid #e0e0e0;
    }
    h1 {
      color: #455a64;
      font-weight: 700;
      font-size: 1.4em;
      margin: 10px 0 0 0;
    }
    .account-section {
      padding: 24px 0;
    }
    .account-name {
      text-align: center;
      font-size: 1.2em;
      font-weight: 600;
      color: #455a64;
      margin: 0 0 8px 0;
    }
    .summary {
      text-align: center;
      font-style: italic;
      color: #607d8b;
      font-size: 15px;
      margin: 0 0 20px 0;
    }
    .kpi-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
      margin-bottom: 16px;
    }
    .kpi-card {
      background-color: transparent;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      padding: 16px 20px;
      text-align: center;
      min-width: 120px;
      flex: 1 1 45%;
      max-width: 48%;
      box-sizing: border-box;
    }
    .kpi-value {
      font-size: 28px;
      font-weight: 700;
      color: #455a64;
      line-height: 1.2;
    }
    .kpi-change {
      font-size: 16px;
    }
    .kpi-label {
      font-size: 13px;
      color: #607d8b;
      margin-top: 4px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .detail-kpis {
      text-align: center;
      padding: 12px 0;
      border-top: 1px solid #e0e0e0;
      border-bottom: 1px solid #e0e0e0;
      margin: 0 0 16px 0;
      font-size: 14px;
      color: #607d8b;
    }
    .detail-kpis strong {
      color: #455a64;
    }
    .best-day {
      text-align: center;
      padding: 12px 16px;
      background-color: transparent;
      border: 1px solid #81c784;
      border-radius: 8px;
      margin: 0 0 16px 0;
      font-size: 14px;
      color: #2e7d32;
    }
    .best-day strong {
      color: #1b5e20;
    }
    .section-title {
      font-size: 15px;
      font-weight: 700;
      color: #455a64;
      margin: 20px 0 12px 0;
      padding-bottom: 6px;
      border-bottom: 1px solid #e0e0e0;
    }
    .top-post {
      padding: 12px 0;
      border-bottom: 1px solid #f0f0f0;
    }
    .top-post:last-child {
      border-bottom: none;
    }
    .post-snippet {
      font-size: 14px;
      color: #37474f;
      margin: 0 0 6px 0;
      line-height: 1.5;
    }
    .post-stats {
      font-size: 12px;
      color: #90a4ae;
      margin: 0 0 4px 0;
    }
    .post-link {
      font-size: 12px;
      color: #1976d2;
      text-decoration: none;
      font-weight: 600;
    }
    .hashtag-row {
      padding: 8px 0;
      font-size: 14px;
      border-bottom: 1px solid #f0f0f0;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .hashtag-row:last-child {
      border-bottom: none;
    }
    .hashtag-name {
      font-weight: 600;
      color: #1976d2;
    }
    .hashtag-stats {
      font-size: 12px;
      color: #90a4ae;
    }
    .account-divider {
      border: none;
      border-top: 2px solid #e0e0e0;
      margin: 0;
    }
    .button-container {
      text-align: center;
      padding: 24px 0 8px 0;
    }
    .button {
      display: inline-block;
      background: linear-gradient(135deg, #455a64 0%, #1c313a 100%);
      color: #ffffff;
      text-decoration: none;
      padding: 12px 24px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 14px;
    }
    .footer {
      text-align: center;
      padding-top: 20px;
      border-top: 1px solid #e0e0e0;
      font-size: 12px;
      color: #607d8b;
      line-height: 1.8;
    }
    .footer a {
      color: #607d8b;
      text-decoration: none;
    }
    .unsubscribe {
      margin-top: 12px;
      font-size: 11px;
      color: #90a4ae;
    }
    .unsubscribe a {
      color: #1976d2;
      text-decoration: none;
    }
    .date-range {
      font-size: 14px;
      color: #607d8b;
      margin: 6px 0 0 0;
      font-weight: 400;
    }
    .trend-up {
      color: #2e7d32;
    }
    .trend-down {
      color: #c62828;
    }

    @media (max-width: 480px) {
      .kpi-card {
        flex: 1 1 100%;
        max-width: 100%;
      }
      .hashtag-row {
        flex-direction: column;
        align-items: flex-start;
        gap: 2px;
      }
    }

    @media (prefers-color-scheme: dark) {
      body {
        background-color: #121212 !important;
        color: #e0e0e0 !important;
      }
      .container {
        background-color: #1e1e1e !important;
        box-shadow: 0 6px 25px rgba(0, 0, 0, 0.3) !important;
      }
      .header {
        border-bottom-color: rgba(255, 255, 255, 0.12) !important;
      }
      h1, .account-name {
        color: #8eb2c3 !important;
      }
      .summary {
        color: #8eacbb !important;
      }
      .kpi-card {
        background-color: transparent !important;
        border-color: rgba(255, 255, 255, 0.12) !important;
      }
      .kpi-value {
        color: #e0e0e0 !important;
      }
      .kpi-label {
        color: #8eacbb !important;
      }
      .detail-kpis {
        border-color: rgba(255, 255, 255, 0.12) !important;
        color: #8eacbb !important;
      }
      .detail-kpis strong {
        color: #e0e0e0 !important;
      }
      .best-day {
        background-color: transparent !important;
        border-color: #4a8c5c !important;
        color: #81c784 !important;
      }
      .best-day strong {
        color: #a5d6a7 !important;
      }
      .section-title {
        color: #8eb2c3 !important;
        border-bottom-color: rgba(255, 255, 255, 0.12) !important;
      }
      .post-snippet {
        color: #e0e0e0 !important;
      }
      .post-stats, .hashtag-stats {
        color: #78909c !important;
      }
      .post-link, .hashtag-name {
        color: #64b5f6 !important;
      }
      .top-post, .hashtag-row {
        border-bottom-color: rgba(255, 255, 255, 0.08) !important;
      }
      .account-divider {
        border-top-color: rgba(255, 255, 255, 0.12) !important;
      }
      .button {
        background: linear-gradient(135deg, #8eb2c3 0%, #607d8b 100%) !important;
        color: #ffffff !important;
      }
      .footer {
        border-top-color: rgba(255, 255, 255, 0.12) !important;
        color: #8eacbb !important;
      }
      .footer a {
        color: #8eacbb !important;
      }
      .unsubscribe {
        color: #78909c !important;
      }
      .unsubscribe a {
        color: #64b5f6 !important;
      }
      .date-range {
        color: #8eacbb !important;
      }
      .trend-up {
        color: #81c784 !important;
      }
      .trend-down {
        color: #ef9a9a !important;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div>
        <img src="cid:logo@analytodon.com" alt="Analytodon" width="120" height="77" style="width:120px; height:77px">
      </div>
      <h1>{{ t.title }}</h1>
      {{#if dateRange}}
        <p class="date-range">{{ dateRange }}</p>
      {{/if}}
    </div>

    {{#each stats as |accountStats|}}
      {{#unless @first}}<hr class="account-divider">{{/unless}}
      <div class="account-section">
        <p class="account-name">{{this.accountName}}</p>

        {{#if this.summarySentence}}
          <p class="summary">{{this.summarySentence}}</p>
        {{/if}}

        <div class="kpi-grid">
          {{#if this.totalEngagement}}
            <div class="kpi-card">
              <div class="kpi-value">{{this.totalEngagement.value}} <span class="kpi-change">{{{this.totalEngagement.change}}}</span></div>
              <div class="kpi-label">{{ ../t.totalEngagement }}</div>
            </div>
          {{/if}}
          <div class="kpi-card">
            <div class="kpi-value">{{this.followers.value}} <span class="kpi-change">{{{this.followers.change}}}</span></div>
            <div class="kpi-label">{{ ../t.followers }} {{ ../t.followersLabel }}</div>
          </div>
          {{#if this.engagementRate}}
            <div class="kpi-card">
              <div class="kpi-value">{{this.engagementRate.value}}</div>
              <div class="kpi-label">{{ ../t.engagementRate }}</div>
            </div>
          {{/if}}
          {{#if this.postingActivity}}
            <div class="kpi-card">
              <div class="kpi-value">{{this.postingActivity.value}} <span class="kpi-change">{{{this.postingActivity.change}}}</span></div>
              <div class="kpi-label">{{ ../t.postingActivity }}</div>
            </div>
          {{/if}}
        </div>

        <div class="detail-kpis">
          <strong>{{this.replies.value}}</strong> {{ ../t.replies }} {{{this.replies.change}}}
          &nbsp;&middot;&nbsp;
          <strong>{{this.boosts.value}}</strong> {{ ../t.boosts }} {{{this.boosts.change}}}
          &nbsp;&middot;&nbsp;
          <strong>{{this.favorites.value}}</strong> {{ ../t.favorites }} {{{this.favorites.change}}}
        </div>

        {{#if this.bestDay}}
          <div class="best-day">
            <strong>{{ ../t.bestDay }}:</strong> {{this.bestDay.dayName}} &mdash; {{this.bestDay.engagement}} {{ ../t.bestDayLabel }}
          </div>
        {{/if}}

        {{#if this.topPosts}}
          <div class="section-title">{{ ../t.topPosts }}</div>
          {{#each this.topPosts}}
            <div class="top-post">
              <p class="post-snippet">{{this.snippet}}</p>
              <p class="post-stats">{{this.boosts}} boosts &middot; {{this.replies}} replies &middot; {{this.favorites}} favorites</p>
              <a href="{{this.url}}" class="post-link">{{ ../../t.viewPost }} &rarr;</a>
            </div>
          {{/each}}
        {{/if}}

        {{#if this.topHashtags}}
          <div class="section-title">{{ ../t.topHashtags }}</div>
          {{#each this.topHashtags}}
            <div class="hashtag-row">
              <span class="hashtag-name">#{{this.hashtag}}</span>
              <span class="hashtag-stats">{{this.tootCount}} {{ ../../t.topHashtagsPosts }} &middot; {{this.totalEngagement}} {{ ../../t.topHashtagsEngagement }}</span>
            </div>
          {{/each}}
        {{/if}}
      </div>
    {{/each}}

    <div class="button-container">
      <a href="{{ appURL }}" class="button">{{ t.dashboardButton }}</a>
    </div>

    <div class="footer">
      <p>
        Analytodon &middot; Raphael St&auml;bler<br>
        {{ supportEmail }} &middot; <a href="{{ marketingURL }}">{{ marketingURL }}</a>
      </p>
      <p class="unsubscribe">
        {{ t.unsubscribe }}
        <a href="{{ unsubscribeURL }}">{{ t.unsubscribeLink }}</a>.
      </p>
    </div>
  </div>
</body>
</html>
